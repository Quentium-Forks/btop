<?xml version="1.0" encoding="UTF-8"?>
<component type="console-application">
    <id>io.github.aristocratos.btop</id>

    <name>btop++</name>
    <summary>Resource monitor that shows usage and stats for processor, memory, disks, network and processes.</summary>

    <metadata_license>CC0-1.0</metadata_license>
    <project_license>Apache-2.0</project_license>
    <developer_name>Quentin Lienhardt</developer_name>

    <description>
        <p>Resource monitor that shows usage and stats for processor, memory, disks, network and processes.</p>
        <p>C++ version and continuation of bashtop and bpytop.</p>
    </description>

    <launchable type="desktop-id">btop.desktop</launchable>

    <icon type="cached">btop.svg</icon>

    <categories>
        <category>System</category>
        <category>Monitor</category>
    </categories>

    <url type="homepage">https://github.com/Quentium-Forks/btop</url>

    <screenshots>
        <screenshot type="default">
            <caption>The btop interface</caption>
            <image>https://raw.githubusercontent.com/Quentium-Forks/btop/HEAD/Img/normal.png</image>
        </screenshot>
        <screenshot>
            <caption>The btop option screen</caption>
            <image>https://raw.githubusercontent.com/Quentium-Forks/btop/HEAD/Img/options-menu.png</image>
        </screenshot>
    </screenshots>

    <provides>
        <binary>btop</binary>
    </provides>
    <releases>
        <release version="@btop_VERSION_MAJOR@.@btop_VERSION_MINOR@.@btop_VERSION_PATCH@" date="@TODAY_ISO_8601@"></release>
    </releases>
</component>
